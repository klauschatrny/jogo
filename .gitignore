# Godot 4

# Godot 4 import cache & editor metadata (os arquivos *.import ao lado dos assets
# SÃO versionados no Godot 4 — só o cache em .godot/ é ignorado).
.godot/
export.cfg
export_presets.cfg

# Build / export output
/build/
/export/
/dist/

# Mono / C# (caso usado futuramente)
.mono/
# Ancorado na raiz: pastas data_* de export do Mono ficam no topo do projeto.
# Sem a barra inicial, este padrão também pegava src/data_layer/ (bug: a camada
# inteira ficou fora do git da Fase 1 até a 4).
/data_*/

# Áudio-fonte (mp3 originais, ~33 MB): pesados demais para o histórico do Git. A arte-fonte
# visual (assets/Design/Parallax, PNGs pequenos) SEGUE versionada — só o áudio fica de fora.
# O que o jogo de fato usa é copiado para assets/audio/ e ESSE é versionado. Mantenha um
# backup dos originais fora do repo: eles não estão no Git.
assets/Design/Audio/

# Editor / OS
.DS_Store
*.swp
*~

# Logs
*.log

# Secrets
*.pem
.env*
