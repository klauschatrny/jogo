; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Fair Despair"
config/description="Soulslike de ação 2D retrô: fogueiras, stamina e chefes que se aprendem morrendo."
run/main_scene="res://src/presentation/scenes/main_menu.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[autoload]

BalanceConfig="*res://src/services/balance_config.gd"
EventBus="*res://src/services/event_bus.gd"
RNGService="*res://src/services/rng_service.gd"
AudioSettings="*res://src/autoload/audio_settings.gd"
Music="*res://src/autoload/music.gd"
Sfx="*res://src/autoload/sfx.gd"
GameManager="*res://src/autoload/game_manager.gd"
KeyBinds="*res://src/autoload/keybinds.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[gui]

theme/default_font_antialiasing=0
theme/default_font_subpixel_positioning=0

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
